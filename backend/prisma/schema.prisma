generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int             @id @default(autoincrement())
  email       String          @unique
  password    String?
  name        String?
  batch       String?
  branch      String?
  createdAt   DateTime        @default(now())
  avatarUrl   String?
  googleId    String?         @unique
  groups      GroupMember[]
  leaderboard Leaderboard?
  accounts    LinkedAccount[]
  leaderboardVisibility LeaderboardVisibility @default(GLOBAL_AND_GROUPS)

  @@index([batch])
  @@index([branch])
  @@index([leaderboardVisibility])
}

enum LeaderboardVisibility {
  GLOBAL_AND_GROUPS
  GROUPS_ONLY
}

model Group {
  id          Int           @id @default(autoincrement())
  name        String
  description String?
  code        String        @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  members     GroupMember[]
}

model GroupMember {
  id       Int      @id @default(autoincrement())
  userId   Int
  groupId  Int
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now())
  group    Group    @relation(fields: [groupId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([userId, groupId])
  @@index([groupId])
}

model LinkedAccount {
  id               Int                @id @default(autoincrement())
  userId           Int
  platform         String
  username         String
  createdAt        DateTime           @default(now())
  currentStreak    Int                @default(0)
  lastActivityDate DateTime?
  totalActiveDays  Int                @default(0)
  dailyActivity    DailyActivity[]
  user             User               @relation(fields: [userId], references: [id])
  snapshots        PlatformSnapshot[]

  @@index([platform])
  @@index([currentStreak])
}

model PlatformSnapshot {
  id              Int           @id @default(autoincrement())
  linkedAccountId Int
  rating          Int?
  problemsSolved  Int?
  rawData         Json
  createdAt       DateTime      @default(now())
  rankTitle       String?
  linkedAccount   LinkedAccount @relation(fields: [linkedAccountId], references: [id])

  @@index([linkedAccountId, createdAt])
  @@index([createdAt])
}

model JobRun {
  id        Int      @id @default(autoincrement())
  jobName   String
  status    String
  message   String?
  createdAt DateTime @default(now())
}

model Leaderboard {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  score     Float
  rank      Int
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@index([rank])
}

model DailyActivity {
  id              Int           @id @default(autoincrement())
  linkedAccountId Int
  date            DateTime
  count           Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  linkedAccount   LinkedAccount @relation(fields: [linkedAccountId], references: [id])

  @@unique([linkedAccountId, date])
}
