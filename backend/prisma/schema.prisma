datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String?
  name      String?
  batch     String?
  branch    String?
  avatarUrl String?
  googleId  String?  @unique
  createdAt DateTime @default(now())

  accounts    LinkedAccount[]
  leaderboard Leaderboard?
}

model LinkedAccount {
  id        Int      @id @default(autoincrement())
  userId    Int
  platform  String
  username  String
  currentStreak   Int @default(0)
  totalActiveDays Int @default(0)
  lastActivityDate DateTime?
  createdAt DateTime @default(now())

  user      User               @relation(fields: [userId], references: [id])
  snapshots PlatformSnapshot[]
  dailyActivity DailyActivity[]
}

model PlatformSnapshot {
  id              Int      @id @default(autoincrement())
  linkedAccountId Int
  rating          Int?
  rankTitle       String?
  problemsSolved  Int?
  rawData         Json
  createdAt       DateTime @default(now())

  linkedAccount LinkedAccount @relation(fields: [linkedAccountId], references: [id])

  @@index([linkedAccountId, createdAt])
  @@index([createdAt])
}

model JobRun {
  id        Int      @id @default(autoincrement())
  jobName   String
  status    String // "success" | "failed"
  message   String?
  createdAt DateTime @default(now())
}

model Leaderboard {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  score     Float
  rank      Int
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model DailyActivity {
  id              Int      @id @default(autoincrement())
  linkedAccountId Int
  date            DateTime // Normalized to YYYY-MM-DD
  count           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  linkedAccount LinkedAccount @relation(fields: [linkedAccountId], references: [id])

  @@unique([linkedAccountId, date])
}
